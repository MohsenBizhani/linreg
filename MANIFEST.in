# Files to include in the source distribution (sdist)
include LICENSE
include README.md
include CHANGELOG.md
include pyproject.toml

# Include all package source
recursive-include linreg *.py

# Include tests so downstream users can verify the build
recursive-include tests *.py

# Exclude generated artefacts
global-exclude __pycache__
global-exclude *.py[co]
global-exclude *.png
